    "build": "tsc -p tsconfig.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.3.6",
    "@types/node": "^24.5.2",
    "typescript": "^5.9.2"
